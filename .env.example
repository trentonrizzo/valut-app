# Supabase (frontend)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Cloudflare R2 (server-side only) — uploads store public URLs under R2_PUBLIC_URL
R2_BUCKET_NAME=vault-storage
R2_BUCKET=vault-storage
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
# Base URL for public objects (required for uploads; e.g. https://pub-xxxxx.r2.dev or custom domain)
R2_PUBLIC_URL=
